/**
 * Knowledge Graph engine — pure functions only, no React, no fetch.
 *
 * SHAPE: nodes are plain objects keyed by id inside per-type buckets
 * (artists, artworks, stories, tours). Edges are their OWN objects, not
 * foreign-key fields — this is the whole point of a graph over a flat
 * table: a relationship can carry its own properties (e.g. an artwork's
 * DISPLAYED_AT edge can record dateInstalled/isPermanent, since art moves).
 *
 * Full graph shape (as stored in the app's `graph` state):
 * {
 *   artists:  { [id]: ArtistNode },
 *   artworks: { [id]: ArtworkNode },
 *   stories:  { [id]: StoryNode },
 *   tours:    { [id]: TourNode },
 *   edges:    { [id]: Edge },
 * }
 * Places themselves are NOT duplicated here — they stay exactly where they
 * already live (World Builder's places/discoveredLocations), and edges just
 * reference their existing ids. Neighborhoods likewise reuse whatever
 * grouping World Builder already has; no new Neighborhood table required to
 * get neighborhood-completion math (see computeNeighborhoodProgress).
 *
 * REVIEW-QUEUE FIELDS (on every AI-touched node/edge):
 *   status:        "pending" | "verified" | "rejected"
 *   suggestedBy:   "ai" | "admin"
 *   sourceNote:    string — where the AI says this came from (so a person
 *                  can actually judge it, not just trust it)
 *   suggestedAt:   epoch ms
 *   editedFields:  { [fieldName]: true } — sim: once you hand-edit a field,
 *                  it's excluded from future "regenerate" calls so a
 *                  redo-this-place pass can never clobber your own work.
 */

let _idCounter = 0;
export function makeId(prefix) {
  _idCounter += 1;
  return `${prefix}-${Date.now().toString(36)}-${_idCounter}`;
}

/* ---------------- Node constructors ---------------- */

export function makeArtistNode({ name, bio = "", portraitUrl = "", website = "", social = [], suggestedBy = "admin", sourceNote = "" } = {}) {
  return {
    id: makeId("artist"), name, bio, portraitUrl, website, social,
    status: suggestedBy === "ai" ? "pending" : "verified",
    suggestedBy, sourceNote, suggestedAt: Date.now(), editedFields: {},
  };
}

export function makeArtworkNode({ title, description = "", dateCreated = "", photos = [], suggestedBy = "admin", sourceNote = "" } = {}) {
  return {
    id: makeId("artwork"), title, description, dateCreated, photos,
    status: suggestedBy === "ai" ? "pending" : "verified",
    suggestedBy, sourceNote, suggestedAt: Date.now(), editedFields: {},
  };
}

export function makeStoryNode({ title, body = "", type = "history", ownerNames = [], businessTypes = [], suggestedBy = "admin", sourceNote = "" } = {}) {
  return {
    id: makeId("story"), title, body, type, ownerNames, businessTypes,
    status: suggestedBy === "ai" ? "pending" : "verified",
    suggestedBy, sourceNote, suggestedAt: Date.now(), editedFields: {},
  };
}

/** Event — from the original data model (openings, exhibitions, workshops,
 *  performances, artist talks, strolls) that never actually got built until
 *  now. Tied to its place via a HOSTS edge, same review-queue treatment as
 *  everything else. */
export function makeEventNode({ title, description = "", date = "", eventType = "event", suggestedBy = "admin", sourceNote = "" } = {}) {
  return {
    id: makeId("event"), title, description, date, eventType,
    status: suggestedBy === "ai" ? "pending" : "verified",
    suggestedBy, sourceNote, suggestedAt: Date.now(), editedFields: {},
  };
}

/**
 * A Tour's stops are an ORDERED array, not edges — order is intrinsic to a
 * tour and simplest kept as a plain array field rather than modeled as N
 * separate STOP_ON edges each carrying an `order` property. Either is
 * defensible; this is the simpler one and it's all the tour trail needs.
 * Each stop: { placeId, artworkId?, wallOffsetMeters?, wallBearingDeg? } —
 * the optional wall fields are what let the tour trail curve in toward a
 * specific mural facade instead of just the place's center point.
 */
export function makeTourNode({ name, theme = "", estimatedMinutes = 30, stops = [], badge = "" } = {}) {
  return { id: makeId("tour"), name, theme, estimatedMinutes, stops, badge, status: "verified" };
}

/* ---------------- Edge constructor ---------------- */

const EDGE_TYPES = [
  "LOCATED_IN", "CREATED_BY", "DISPLAYED_AT", "EXHIBITED_AT",
  "HOSTS", "PARTICIPATES_IN", "NEAR", "MENTIONS", "COLLABORATED_WITH",
];
export function makeEdge({ type, from, to, properties = {}, suggestedBy = "admin", sourceNote = "" }) {
  if (!EDGE_TYPES.includes(type)) throw new Error(`Unknown edge type: ${type}`);
  return {
    id: makeId("edge"), type, from, to, properties,
    status: suggestedBy === "ai" ? "pending" : "verified",
    suggestedBy, sourceNote, suggestedAt: Date.now(),
  };
}

/* ---------------- Review-queue transitions (all pure: graph in, graph out) ---------------- */

export function approveItem(graph, kind, id) {
  const bucket = { artist: "artists", artwork: "artworks", story: "stories", event: "events", edge: "edges" }[kind];
  if (!bucket || !graph[bucket][id]) return graph;
  return { ...graph, [bucket]: { ...graph[bucket], [id]: { ...graph[bucket][id], status: "verified" } } };
}

export function rejectItem(graph, kind, id) {
  const bucket = { artist: "artists", artwork: "artworks", story: "stories", event: "events", edge: "edges" }[kind];
  if (!bucket || !graph[bucket][id]) return graph;
  return { ...graph, [bucket]: { ...graph[bucket], [id]: { ...graph[bucket][id], status: "rejected" } } };
}

/** Editing a field marks it admin-owned (locked from future regenerate) and,
 *  if this is the person's first touch on an AI-suggested item, promotes it
 *  straight to verified — an edited fact is a reviewed fact. */
export function editField(graph, kind, id, field, value) {
  const bucket = { artist: "artists", artwork: "artworks", story: "stories", event: "events" }[kind];
  if (!bucket || !graph[bucket][id]) return graph;
  const node = graph[bucket][id];
  const next = {
    ...node, [field]: value,
    editedFields: { ...node.editedFields, [field]: true },
    status: node.status === "pending" ? "verified" : node.status,
  };
  return { ...graph, [bucket]: { ...graph[bucket], [id]: next } };
}

/** Which fields are safe to regenerate: everything EXCEPT ones the admin has
 *  personally edited. This is the actual safeguard behind "regenerate should
 *  never silently overwrite something you've already touched." */
export function regeneratableFields(node, allFieldNames) {
  return allFieldNames.filter(f => !node.editedFields || !node.editedFields[f]);
}

/* ---------------- Derived collection queries — nothing stored, all computed ---------------- */

const verified = obj => Object.values(obj || {}).filter(n => n.status === "verified");

/** Every verified edge of a given type, as {from,to,properties} triples. */
function edgesOfType(graph, type) {
  return verified(graph.edges).filter(e => e.type === type);
}

/** Artist collection progress: how many of an artist's known artworks has
 *  the player actually unlocked (via checkIns/unlockedDiscoverables). */
export function computeArtistProgress(graph, artistId, unlockedDiscoverableIds) {
  const artworkIds = edgesOfType(graph, "CREATED_BY")
    .filter(e => e.to === artistId)
    .map(e => e.from);
  const total = artworkIds.length;
  const found = artworkIds.filter(id => unlockedDiscoverableIds.has(id)).length;
  return { total, found, pct: total ? found / total : 0 };
}

/** Neighborhood completion, generalized across every collection type at
 *  once, purely from LOCATED_IN + whatever discoverable edges exist for
 *  places in that neighborhood. `placesInNeighborhood` is supplied by the
 *  caller (World Builder's existing place list filtered by neighborhoodId)
 *  since Place itself lives outside this engine. */
export function computeNeighborhoodProgress(graph, placeIds, checkIns) {
  const placeSet = new Set(placeIds);
  const artworksAtPlaces = edgesOfType(graph, "DISPLAYED_AT").filter(e => placeSet.has(e.to));
  const totalPlaces = placeIds.length;
  const visitedPlaces = placeIds.filter(id => checkIns[id]).length;
  return {
    places: { total: totalPlaces, found: visitedPlaces },
    artworks: { total: artworksAtPlaces.length }, // "found" side computed by caller against unlockedDiscoverables, same pattern as computeArtistProgress
  };
}

/** Tour completion: how many ordered stops have a check-in. */
export function computeTourProgress(tour, checkIns) {
  const total = tour.stops.length;
  const found = tour.stops.filter(s => checkIns[s.placeId]).length;
  return { total, found, pct: total ? found / total : 0, nextStop: tour.stops.find(s => !checkIns[s.placeId]) || null };
}

/** "Nearby creative places" / tour recommendation: places connected to the
 *  current place by a NEAR edge, within an optional max hop count of 1 (i.e.
 *  direct neighbors only — this is intentionally not a full graph search,
 *  since NEAR edges are precomputed proximity, not a live traversal). */
export function nearbyPlaceIds(graph, placeId) {
  return edgesOfType(graph, "NEAR")
    .filter(e => e.from === placeId || e.to === placeId)
    .map(e => (e.from === placeId ? e.to : e.from));
}

/* ---------------- AI research: prompt + parse (no fetch here — App.jsx calls callModel) ---------------- */

/**
 * Builds the {system, user} prompt for researching one Creative Place.
 * Deliberately conservative: told to extract facts ONLY from the search
 * results it's given, and to say so explicitly when the results don't
 * support a confident fact — never to fill gaps from general "knowledge" of
 * similar venues. Search (via Tavily, see api/search.js) now happens as its
 * OWN step before this prompt is ever built, specifically so sourceNote can
 * be a REAL source URL instead of the model's own unverifiable claim about
 * why it believes something — a small real venue with real GPS coordinates
 * deserves an honest "we found nothing" over invented content.
 */
export function buildResearchPrompt(place, searchResults = []) {
  const system = `You are extracting structured facts about a real, physical creative venue from search results, for a location-based game. Use ONLY the information in the search results provided below — do not add anything from general knowledge, and do not generalize from similar venues. If the search results don't clearly support a fact about THIS exact venue, omit it. Respond with ONLY a JSON object, no prose, no markdown fences, matching exactly:
{
  "funFacts": [{ "fact": string, "sourceUrl": string }],
  "profile": { "description": string, "businessTypes": [string], "ownerNames": [string], "sourceUrl": string } | null,
  "events": [{ "title": string, "description": string, "date": string, "eventType": "opening"|"exhibition"|"workshop"|"performance"|"artist_talk"|"stroll"|"event", "sourceUrl": string }],
  "artists": [{ "name": string, "bio": string, "sourceUrl": string }],
  "artworks": [{ "title": string, "description": string, "artistName": string|null, "sourceUrl": string }],
  "history": { "body": string, "sourceUrl": string } | null
}
"funFacts" are short, genuinely interesting or surprising tidbits about the venue — a quirky detail, an unusual anecdote, something a visitor would enjoy knowing. Each one sentence or two, casual tone, pulled directly from the search results — never invented. This is the category to prioritize filling if the results support it, even when the more formal categories below don't have enough for a confident entry.
"profile" is a general "what is this place" summary: what kind of venue it is (e.g. "gallery on the ground floor with a tattoo studio upstairs"), and current use — NOT its founding history (that's the separate "history" field). "businessTypes" are short tags like "gallery", "tattoo studio", "music venue". "ownerNames" are real names ONLY if a source directly states who owns/runs the venue.
CRITICAL: never infer or guess any identity, ownership, or demographic characterization (e.g. "Black-owned", "family-owned", "woman-owned") from a name, photo, or general impression. Only include such a characterization if a cited source states it EXPLICITLY, in those or equivalent words, as the venue's own description of itself — and quote/attribute it plainly in "description" when you do. If sources don't explicitly say this, omit it entirely rather than guessing.
"events" are specific, dated (or date-ranged) happenings — an opening, an exhibition run, a workshop — not the venue's general hours or a recurring weekly special. If no specific event with an actual date is mentioned, return an empty array.
"sourceUrl" MUST be one of the exact URLs given below — never invent or paraphrase a URL. If the search results contain nothing specific and confident about this venue at all, return every field empty/null — an honest empty result is far better than invented content for a real place with real GPS coordinates.`;
  const sourcesBlock = searchResults.length
    ? searchResults.map((r, i) => `[Source ${i + 1}] ${r.url}\n${r.title}\n${r.content}`).join("\n\n")
    : "(no search results were found for this venue)";
  const user = `Venue: "${place.name}"\nCategory: ${place.category || "unknown"}\nLocation: ${place.address || `${place.lat}, ${place.lng}`}\nNeighborhood: ${place.neighborhood || "Castleberry Hill, Atlanta"}\n\nSearch results:\n${sourcesBlock}`;
  return { system, user };
}

/** Builds the search query the research flow runs BEFORE calling the AI —
 *  scoped to the venue's real name/address so results are actually about
 *  this specific place, not the category in general. */
export function buildResearchQuery(place) {
  return `"${place.name}" ${place.address || ""} gallery mural artist Atlanta`.trim();
}

/** Turns the parsed AI JSON into pending graph nodes+edges, tagged for
 *  review. Low-confidence items get an extra "(unverified)" marker folded
 *  into sourceNote so they're visually distinct in the review queue even
 *  before a human looks closely. */
export function suggestionsToGraphDelta(parsed, placeId) {
  const artists = [];
  const artworks = [];
  const events = [];
  const edges = [];
  const artistIdByName = {};

  for (const a of parsed.artists || []) {
    const node = makeArtistNode({ name: a.name, bio: a.bio || "", suggestedBy: "ai", sourceNote: a.sourceUrl || "" });
    artists.push(node);
    artistIdByName[a.name] = node.id;
    edges.push(makeEdge({ type: "EXHIBITED_AT", from: node.id, to: placeId, suggestedBy: "ai", sourceNote: a.sourceUrl || "" }));
  }
  for (const w of parsed.artworks || []) {
    const node = makeArtworkNode({ title: w.title, description: w.description || "", suggestedBy: "ai", sourceNote: w.sourceUrl || "" });
    artworks.push(node);
    edges.push(makeEdge({ type: "DISPLAYED_AT", from: node.id, to: placeId, suggestedBy: "ai", sourceNote: w.sourceUrl || "" }));
    const artistId = w.artistName && artistIdByName[w.artistName];
    if (artistId) edges.push(makeEdge({ type: "CREATED_BY", from: node.id, to: artistId, suggestedBy: "ai", sourceNote: w.sourceUrl || "" }));
  }
  for (const ev of parsed.events || []) {
    const node = makeEventNode({ title: ev.title, description: ev.description || "", date: ev.date || "", eventType: ev.eventType || "event", suggestedBy: "ai", sourceNote: ev.sourceUrl || "" });
    events.push(node);
    edges.push(makeEdge({ type: "HOSTS", from: placeId, to: node.id, suggestedBy: "ai", sourceNote: ev.sourceUrl || "" }));
  }
  const stories = [];
  // Fun facts: each one is its own small Story so it can be approved/rejected
  // independently — a place might have three great fun facts and one dud,
  // and there's no reason rejecting one should cost the others.
  for (const ff of parsed.funFacts || []) {
    if (!ff.fact) continue;
    const node = makeStoryNode({ title: "Fun fact", body: ff.fact, type: "fact", suggestedBy: "ai", sourceNote: ff.sourceUrl || "" });
    stories.push(node);
    edges.push(makeEdge({ type: "MENTIONS", from: node.id, to: placeId, suggestedBy: "ai", sourceNote: ff.sourceUrl || "" }));
  }
  if (parsed.history && parsed.history.body) {
    stories.push(makeStoryNode({ title: "History", body: parsed.history.body, type: "history", suggestedBy: "ai", sourceNote: parsed.history.sourceUrl || "" }));
    edges.push(makeEdge({ type: "MENTIONS", from: stories[stories.length - 1].id, to: placeId, suggestedBy: "ai", sourceNote: parsed.history.sourceUrl || "" }));
  }
  // The general "what is this place, who runs it" profile — separate from
  // History (founding story) — this is what actually answers "tell me about
  // it": venue type, current use, and ownership IF a source explicitly
  // states it (see the prompt's guard against inferring identity/ownership
  // demographics from indirect cues).
  if (parsed.profile && (parsed.profile.description || (parsed.profile.ownerNames || []).length)) {
    stories.push(makeStoryNode({
      title: "About this place", body: parsed.profile.description || "", type: "profile",
      ownerNames: parsed.profile.ownerNames || [], businessTypes: parsed.profile.businessTypes || [],
      suggestedBy: "ai", sourceNote: parsed.profile.sourceUrl || "",
    }));
    edges.push(makeEdge({ type: "MENTIONS", from: stories[stories.length - 1].id, to: placeId, suggestedBy: "ai", sourceNote: parsed.profile.sourceUrl || "" }));
  }
  return { artists, artworks, events, stories, edges };
}

/** Merges a delta (from suggestionsToGraphDelta, or a hand-authored add)
 *  into the full graph state. Pure — returns a new graph object. */
export function mergeGraphDelta(graph, delta) {
  const next = { ...graph, artists: { ...graph.artists }, artworks: { ...graph.artworks }, events: { ...(graph.events || {}) }, stories: { ...graph.stories }, edges: { ...graph.edges } };
  (delta.artists || []).forEach(n => { next.artists[n.id] = n; });
  (delta.artworks || []).forEach(n => { next.artworks[n.id] = n; });
  (delta.events || []).forEach(n => { next.events[n.id] = n; });
  (delta.stories || []).forEach(n => { next.stories[n.id] = n; });
  (delta.edges || []).forEach(e => { next.edges[e.id] = e; });
  return next;
}

/** Everything still awaiting review, grouped by the place it's attached to
 *  (via edges) — this is exactly the shape World Builder's review queue
 *  renders: a card stack per place. */
export function pendingByPlace(graph) {
  const groups = {}; // placeId -> { artists:[], artworks:[], events:[], stories:[] }
  const ensure = pid => (groups[pid] = groups[pid] || { artists: [], artworks: [], events: [], stories: [] });
  Object.values(graph.edges).forEach(e => {
    if (e.status !== "pending") return;
    if (e.type === "EXHIBITED_AT" && graph.artists[e.from]?.status === "pending") ensure(e.to).artists.push(graph.artists[e.from]);
    if (e.type === "DISPLAYED_AT" && graph.artworks[e.from]?.status === "pending") ensure(e.to).artworks.push(graph.artworks[e.from]);
    if (e.type === "MENTIONS" && graph.stories[e.from]?.status === "pending") ensure(e.to).stories.push(graph.stories[e.from]);
    // HOSTS runs place -> event (the reverse direction of the others, which
    // all point FROM the content node TO the place) — a place hosts an
    // event, an event doesn't "point at" its venue the way an artwork does.
    if (e.type === "HOSTS" && graph.events?.[e.to]?.status === "pending") ensure(e.from).events.push(graph.events[e.to]);
  });
  return groups;
}
